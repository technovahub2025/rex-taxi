{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://www.redtaxi.co.in/$1"
    },
    {
      "src": "/test_redTaxi/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/test_redTaxi/mirror/(.*)",
      "dest": "/mirror/$1"
    },
    {
      "src": "/test_redTaxi/vite.svg",
      "dest": "/vite.svg"
    },
    {
      "src": "/test_redTaxi",
      "dest": "/index.html"
    },
    {
      "src": "/test_redTaxi/(.*)",
      "dest": "/index.html"
    }
  ]
}
